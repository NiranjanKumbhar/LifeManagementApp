# LifeSync API — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored; this file is committed as documentation.

# PostgreSQL connection string (Supabase).
# Project Settings → Database → Connect → Session pooler (port 5432).
# Use the Session pooler (5432), not the Transaction pooler (6543): postgres-js
# relies on prepared statements, which the transaction pooler does not support.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Clerk backend secret key (JWT verification + JIT user provisioning).
# Clerk Dashboard → API Keys → Secret key.
CLERK_SECRET_KEY=sk_test_xxx

# Clerk webhook signing secret (Dashboard → Webhooks → endpoint → Signing Secret).
# Optional in dev: the auth middleware provisions users just-in-time.
CLERK_WEBHOOK_SECRET=whsec_xxx

# New users are auto-added to this workspace. Keep in sync with the web app's
# NEXT_PUBLIC_DEFAULT_WORKSPACE_ID. Leave empty to disable auto-membership.
DEFAULT_WORKSPACE_ID=

# HTTP port the API listens on.
PORT=3001

# Allowed CORS origin for the web client.
WEB_ORIGIN=http://localhost:3000
