{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server-entry.ts",
      "default": "./src/server-entry.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seeds/development.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@lifesync/shared-types": "workspace:*",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.38.3",
    "inngest": "^3.29.0",
    "postgres": "^3.4.5",
    "resend": "^6.12.4",
    "svix": "^1.42.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.14",
    "@faker-js/faker": "^9.3.0",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
